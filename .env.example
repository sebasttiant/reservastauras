# Conexión a Postgres.
# Para `pnpm dev` desde el host con `docker compose up -d db`, usá `localhost`.
# El servicio web del docker-compose.yml sobrescribe esto y usa `db:5432`
# (red interna de Docker), así que no hace falta cambiarlo para el flujo full-docker.
DATABASE_URL="postgresql://reservas:reservas@localhost:5432/reservastauras?schema=public"

# Credenciales del contenedor de Postgres definido en docker-compose.yml.
POSTGRES_USER="reservas"
POSTGRES_PASSWORD="reservas"
POSTGRES_DB="reservastauras"

# Mínimo 32 caracteres aleatorios. Generar con: openssl rand -base64 48
SESSION_SECRET="change-me-to-at-least-32-random-characters"

# SMTP — opcional. Si SMTP_HOST queda vacío el envío falla y se registra en
# Reservation.emailError sin revertir la confirmación humana.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Reservas Tauras <reservas@example.com>"

# Solo necesarios al correr `pnpm db:seed`. La seed exige una password real
# distinta del placeholder.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-before-running-seed"
