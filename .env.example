# Conexión a Postgres.
# Para `pnpm dev` desde el host con `docker compose up -d db`, usá `localhost`.
# El servicio web del docker-compose.yml NO hereda esta variable: arma su
# propia DATABASE_URL a partir de POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB
# y la red interna `db:5432`.
DATABASE_URL="postgresql://reservas:CHANGE_ME@localhost:5432/reservastauras?schema=public"

# Credenciales del contenedor de Postgres definido en docker-compose.yml.
POSTGRES_USER="reservas"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="reservastauras"

# Mínimo 32 caracteres aleatorios. Generar con: openssl rand -base64 48
SESSION_SECRET="GENERATE_WITH_OPENSSL_RAND_BASE64_48"

# SMTP — opcional. Si SMTP_HOST queda vacío el envío falla y se registra en
# Reservation.emailError sin revertir la confirmación humana.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Reservas Tauras <reservas@example.com>"

# Solo necesarios al correr `pnpm db:seed`. La seed exige una password real
# distinta del placeholder; el placeholder existe únicamente para que el
# arranque del compose no falle por variable faltante.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME_BEFORE_SEED_DO_NOT_USE_IN_PRODUCTION"
