{
  "name": "reservastauras",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "24.15.0",
    "pnpm": ">=11.1.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:seed": "tsx --env-file-if-exists=.env prisma/seed.ts",
    "db:clear-reservations": "tsx --env-file-if-exists=.env scripts/clear-reservations.ts",
    "photos:seed": "tsx --env-file-if-exists=.env scripts/seed-zone-photos.ts",
    "scripts:check-env": "tsx scripts/check-env.ts",
    "scripts:purge-login-attempts": "tsx scripts/purge-login-attempts.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "exceljs": "^4.4.0",
    "jose": "6.2.3",
    "next": "16.2.6",
    "nodemailer": "8.0.7",
    "pdf-lib": "^1.17.1",
    "pg": "8.21.0",
    "prisma": "7.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "server-only": "0.0.1",
    "sharp": "^0.34.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "24.12.4",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
