generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Admin {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         AdminRole     @default(ADMIN)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  confirmed    Reservation[] @relation("ReservationConfirmedBy")
  rejected     Reservation[] @relation("ReservationRejectedBy")
  cancelled    Reservation[] @relation("ReservationCancelledBy")
  createdReservations Reservation[] @relation("ReservationCreatedBy")
  auditLogs    AuditLog[]
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  phone        String?
  createdAt    DateTime      @default(now())
  reservations Reservation[]
}

model Location {
  id               String        @id @default(cuid())
  slug             String        @unique
  name             String
  shortName        String
  reservationLabel String
  address          String?
  phone            String?
  whatsappUrl      String?
  logoPath         String?
  heroImagePath    String?
  isActive         Boolean       @default(true)
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reservations     Reservation[]

  @@index([isActive, sortOrder])
}

model Reservation {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId      String
  location        Location          @relation(fields: [locationId], references: [id])
  reservationDate DateTime          @db.Date
  reservationTime String
  area            String?
  partySize       Int
  notes           String?
  customerLanguage String           @default("es")
  source          String            @default("web")
  createdByAdminId String?
  createdByAdmin Admin?             @relation("ReservationCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  status          ReservationStatus @default(PENDING)
  confirmedAt     DateTime?
  confirmedById   String?
  confirmedBy     Admin?            @relation("ReservationConfirmedBy", fields: [confirmedById], references: [id])
  rejectedAt      DateTime?
  rejectedById    String?
  rejectedBy      Admin?            @relation("ReservationRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectionReason String?
  cancelledAt     DateTime?
  cancelledById   String?
  cancelledBy     Admin?            @relation("ReservationCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancellationReason String?
  emailError      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, reservationDate, reservationTime])
  @@index([locationId, reservationDate, reservationTime])
  @@index([area])
  @@index([source])
  @@index([createdByAdminId])
  @@index([rejectedById])
  @@index([cancelledById])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  // Email normalizado (lowercase + trim). Tratado como string opaco: NO es FK
  // al Admin para evitar filtrar si el email existe o no.
  emailKey  String
  // IP del cliente cuando se puede leer de un header confiable; null si no
  // hay un origen claro. No inventamos valores.
  ipKey     String?
  success   Boolean
  createdAt DateTime @default(now())
  // Diagnóstico interno; nunca se expone al usuario.
  // Valores: "no-such-admin" | "inactive" | "wrong-password" | "locked-email"
  // | "locked-ip" | "rate-limited" | "validation"
  reason    String?

  @@index([emailKey, createdAt])
  @@index([ipKey, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id           String     @id @default(cuid())
  event        String
  actorAdminId String?
  actorEmail   String?
  actorRole    AdminRole?
  resourceType String?
  resourceId   String?
  outcome      String     @default("SUCCESS")
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime   @default(now())
  actorAdmin   Admin?     @relation(fields: [actorAdminId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([actorAdminId, createdAt])
  @@index([resourceType, resourceId])
}
